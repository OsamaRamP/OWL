<templates xml:space="preserve">

    <t t-name="owl_course.ProductCard">
        <div class="product-card card h-100">
            <img
                    class="product-card__image card-img-top"
                    t-att-src="'/web/image/product.template/'+props.product.id +'/image_1920'"
                    t-att-alt="props.product.name"
            />
            <div class="card-body">
                <h4 class="product-card__title" t-esc="props.product.name"/>

                <p class="product-card__price">
                    Price:
                    <span t-esc="props.product.price"/>
                </p>

                <button class="btn btn-primary"  t-on-click="() => props.onMoreInfo(props.product)">
                    More Info
                </button>

            </div>
        </div>
    </t>

</templates>
